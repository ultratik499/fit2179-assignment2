{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "The Footprint of Melbourne Transit & Pedestrian Movement",
    "subtitle": "Comparing Train Station Patronage with CBD Pedestrian Sensor Locations",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "anchor": "start",
    "color": "#111111"
  },
  "width": 800,
  "height": 600,
  "config": {    
    "view": {"stroke": "transparent"},
    "font": "sans-serif"
  },
  "projection": {
    "type": "mercator",
    "center": [144.9631, -37.8136],
    "scale": 120000
  },
  "layer": [
    {
      "name": "Background Map Layer",
      "data": {
        "url": "https://raw.githubusercontent.com/tonywr71/GeoJson-Data/master/australia-postcodes.geojson",
        "format": {"type": "json", "property": "features"}
      },
      "transform": [
        {
          "filter": "datum.properties.postcode == '3000' || datum.properties.postcode == '3006' || datum.properties.postcode == '3008' || datum.properties.postcode == '3053'"
        }
      ],
      "mark": {
        "type": "geoshape",
        "fill": "#f4f4f2",
        "stroke": "#dcdcdc",
        "strokeWidth": 1.5
      }
    },
    {
      "name": "Train Station Patronage Layer",
      "data": {
        "url": "c9507eb5-aa48-4a43-aa09-c10a24d1f2fe.csv"
      },
      "encoding": {
        "longitude": {"field": "Stop_long", "type": "quantitative"},
        "latitude": {"field": "Stop_lat", "type": "quantitative"}
      },
      "layer": [
        {
          "mark": {
            "type": "circle",
            "opacity": 0.75,
            "stroke": "#004B87",
            "strokeWidth": 1
          },
          "encoding": {
            "size": {
              "field": "Pax_annual",
              "type": "quantitative",
              "title": "Annual Patronage",
              "scale": {"range": [100, 2500]}
            },
            "color": {
              "field": "Pax_annual",
              "type": "quantitative",
              "title": "Patronage Volume",
              "scale": {"scheme": "blues"}
            },
            "tooltip": [
              {"field": "Stop_name", "type": "nominal", "title": "Station"},
              {"field": "Pax_annual", "type": "quantitative", "title": "Annual Entries", "format": ","},
              {"field": "Pax_AM_peak", "type": "quantitative", "title": "AM Peak Traffic", "format": ","},
              {"field": "Pax_PM_peak", "type": "quantitative", "title": "PM Peak Traffic", "format": ","}
            ]
          }
        },
        {
          "mark": {
            "type": "text",
            "dy": -15,
            "fontWeight": "bold",
            "fontSize": 10,
            "color": "#2c3e50"
          },
          "encoding": {
            "text": {
              "condition": {
                "test": "datum.Stop_name == 'Flinders Street' || datum.Stop_name == 'Southern Cross' || datum.Stop_name == 'Melbourne Central'",
                "field": "Stop_name",
                "type": "nominal"
              },
              "value": ""
            }
          }
        }
      ]
    },
    {
      "name": "Pedestrian Sensors Layer",
      "data": {
        "url": "pedestrian-counting-system-sensor-locations.csv"
      },
      "mark": {
        "type": "point",
        "shape": "diamond",
        "size": 60,
        "fill": "#ff7f0e",
        "stroke": "#b35806",
        "strokeWidth": 1,
        "opacity": 0.8
      },
      "encoding": {
        "longitude": {"field": "Longitude", "type": "quantitative"},
        "latitude": {"field": "Latitude", "type": "quantitative"},
        "tooltip": [
          {"field": "Sensor_Description", "type": "nominal", "title": "Pedestrian Sensor"},
          {"field": "Location_Type", "type": "nominal", "title": "Type"},
          {"field": "Status", "type": "nominal", "title": "Status (Active=A)"}
        ]
      }
    }
  ]
}
